# API URL configuration (optional)
# If provided, this URL will take precedence over the dynamically resolved IP address.
# EXPO_PUBLIC_API_URL=http://192.168.1.100:8000

# Fallback IP address (optional)
# Used if dynamic resolution via Expo debuggerHost fails. Defaults to 'localhost' if not set.
# EXPO_PUBLIC_BACKEND_IP=192.168.1.100
